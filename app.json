{
  "expo": {
    "name": "Asteres",
    "slug": "asteres",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-asteres.png",
    "scheme": "asteres",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo-asteres.png",
      "resizeMode": "contain",
      "backgroundColor": "#05050A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-asteres.png",
        "backgroundColor": "#05050A"
      },
      "package": "com.lohandosreis.asteres"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "828687fe-7279-497e-84cc-3c5c2226a139"
      }
    }
  }
}
